{
    "window.autoDetectColorScheme": true,
    "workbench.preferredLightColorTheme": "Dark 2026",
    "chat.tips.enabled": false,
    "github.copilot.chat.claudeAgent.allowDangerouslySkipPermissions": true,
    "github.copilot.chat.cli.branchSupport.enabled": true,
    "github.copilot.chat.cli.planExitMode.enabled": true,
    "github.copilot.chat.cli.sessionController.enabled": true,
    "github.copilot.chat.localeOverride": "zh-CN",
    "github.copilot.chat.otel.enabled": true,
    "python.analysis.typeCheckingMode": "standard",
    "github.copilot.chat.conversationTranscriptLookup.enabled": true,
    "github.copilot.chat.agent.omitFileAttachmentContents": true,
    "github.copilot.chat.anthropic.tools.websearch.maxUses": 10,
    "github.copilot.chat.executionSubagent.enabled": true,
    "github.copilot.chat.executionSubagent.toolCallLimit": 10,
    "github.copilot.chat.githubMcpServer.enabled": true,
    "github.copilot.chat.installExtensionSkill.enabled": true,
    "github.copilot.chat.languageContext.fix.typescript.enabled": true,
    "github.copilot.chat.languageContext.inline.typescript.enabled": true,
    "github.copilot.chat.languageContext.typescript.includeDocumentation": true,
    "github.copilot.chat.newWorkspace.useContext7": true,
    "github.copilot.chat.notebook.alternativeFormat": "markdown",
    "github.copilot.chat.notebook.followCellExecution.enabled": true,
    "github.copilot.chat.workspace.maxLocalIndexSize": 1000000,
    "github.copilot.chat.workspace.maxDiffSizeBeforeUsingExternalIngest": 1000,
    "chat.agent.maxRequests": 500,
    "github.copilot.chat.agentHistorySummarizationMode": "",
    "github.copilot.chat.anthropic.thinking.budgetTokens": "<redacted>"
    "github.copilot.chat.anthropic.thinking.forceExtendedThinking": true,
    "github.copilot.chat.cli.forkSessions.enabled": true,
    "github.copilot.chat.summarizeAgentConversationHistory.enabled": false,
    "github.copilot.enable": {
        "*": true,
        "plaintext": false,
        "markdown": true,
        "scminput": false
    },
    "python.createEnvironment.trigger": "off",
    "python.defaultInterpreterPath": "e:\\Projects\\SCP\\.venv\\Scripts\\python.exe",
    "terminal.integrated.fontFamily": "\"JetBrainsMono Nerd Font Mono\", \"JetBrainsMono Nerd Font\", \"Consolas\", \"monospace\"",
    "github.copilot.chat.githubMcpServer.channel": "insiders",
    "security.workspace.trust.untrustedFiles": "open",
    "security.promptForLocalFileProtocolHandling": false
}

